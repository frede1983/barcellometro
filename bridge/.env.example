# ===== BARCELLOMETRO - Bridge TikTok locale =====
# Copia in .env e compila.

# URL del Barcellometro sul VPS (senza /bridge, lo aggiunge lo script)
BARCELLO_URL=ws://srv1013438.hstgr.cloud:3900

# Token bridge: DEVE essere identico a quello impostato nel Barcellometro
# (Impostazioni -> TikTok -> Token bridge)
BRIDGE_TOKEN=

# Opzionale: cookie sessionid TikTok (sblocca live ristrette, riduce rate-limit)
TIKTOK_SESSION_ID=
