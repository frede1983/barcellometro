# ============ BARCELLOMETRO - Configurazione ============

# Porta webapp (dashboard su http://localhost:3900)
PORT=3900

# --- AI (classificazione ibrida dei picchi) ---
# Provider: claude-sdk = CLI Claude Code con la tua SUBSCRIPTION (consigliato, nessun costo per token)
#           api        = Anthropic API diretta (serve ANTHROPIC_API_KEY)
#           off        = solo keyword
AI_PROVIDER=claude-sdk
# Modello: per claude-sdk usa alias (haiku|sonnet|opus), per api il nome completo
AI_MODEL=haiku
# Solo per provider=api:
ANTHROPIC_API_KEY=
# Per claude-sdk headless su VPS: token generato con `claude setup-token`
# CLAUDE_CODE_OAUTH_TOKEN=
# Score minimo per interpellare l'AI (0-100) e cooldown tra chiamate (secondi)
AI_TRIGGER_SCORE=40
AI_COOLDOWN_SEC=90

# --- Sicurezza dashboard (obbligatoria su VPS pubblico) ---
# Se impostata: login richiesto, utente "barcello" + questa password
DASH_PASSWORD=

# --- Discord (opzionale: serve solo per monitorare Discord) ---
# Crea un bot su https://discord.com/developers/applications
# Abilita MESSAGE CONTENT INTENT, poi invita il bot nel server
DISCORD_BOT_TOKEN=

# --- TikTok (opzionale) ---
# API key Euler Stream per connessioni piu' stabili: https://www.eulerstream.com
# Senza chiave funziona comunque (rate limit del sign server gratuito)
TIKTOK_SIGN_API_KEY=

# --- Audio / Whisper ---
# Sidecar di trascrizione (whisper/server.py). Se spento, il Barcellometro funziona solo su chat.
AUDIO_ENABLED=true
WHISPER_URL=http://127.0.0.1:3901
WHISPER_PORT=3901
# Modello faster-whisper: tiny | base | small | medium (small = buon compromesso per l'italiano)
WHISPER_MODEL=small
# Durata chunk audio TikTok in secondi
AUDIO_CHUNK_SEC=8
